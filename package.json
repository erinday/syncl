{
  "name": "@erinday/syncl",
  "version": "2.1.1",
  "description": "Reactive storage sync (localStorage / sessionStorage). No magic",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "clean": "rimraf dist"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "localstorage",
    "sessionStorage",
    "storage",
    "sync",
    "event",
    "browser",
    "state"
  ],
  "author": "Erinday",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erinday/syncl.git"
  },
  "homepage": "https://github.com/erinday/syncl#readme"
}
